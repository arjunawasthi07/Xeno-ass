# =========================================================================
# Xeno CRM Monorepo Environment Configuration Example
# Copy this file to crm-backend/.env and channel-service/.env respectively
# =========================================================================

# --- 1. AI API Key Configuration (Required inside crm-backend/.env only) ---
# Paste your Google Gemini developer API Key. 
# If left empty, the CRM will run in Mock AI mode using local heuristics.
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- 2. Database Selection (Defaults to SQLite if DB_CLIENT is omitted) ---
# To switch the application database to PostgreSQL, uncomment and configure below.
# DB_CLIENT=pg

# --- 3. PostgreSQL Credentials (Used only if DB_CLIENT=pg) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here

# --- 4. Database Names (Used only if DB_CLIENT=pg) ---
# Place in crm-backend/.env
PG_DATABASE=xeno_crm

# Place in channel-service/.env
PG_SIMULATOR_DATABASE=xeno_simulator

# --- 5. Port Configurations (Defaults to 3000 / 3001 if omitted) ---
# CRM Backend port
PORT=3000

# Channel Simulator port
# PORT=3001
